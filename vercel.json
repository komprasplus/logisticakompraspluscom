{
  "rewrites": [
    {
      "source": "/:slug/catalogo",
      "destination": "/api/catalog-handler"
    },
    {
      "source": "/:slug/catalogo/lista/:listaSlug",
      "destination": "/api/catalog-handler"
    },
    {
      "source": "/:slug/catalogo/:productId",
      "destination": "/api/catalog-handler"
    },
    {
      "source": "/((?!api|assets|favicon|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(js|css|woff2|woff|ttf|svg|jpg|jpeg|png|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
