{
  "rewrites": [
    {
      "source": "/:slug/catalogo",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|discordbot|telegrambot|whatsapp|pinterest|skypeuripreview|embedly|vkshare|w3c_validator|redditbot|applebot|yandex|googlebot|bingbot|duckduckbot|msnbot|petalbot).*"
        }
      ],
      "destination": "/api/catalog-handler"
    },
    {
      "source": "/:slug/catalogo/lista/:listaSlug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|discordbot|telegrambot|whatsapp|pinterest|skypeuripreview|embedly|vkshare|w3c_validator|redditbot|applebot|yandex|googlebot|bingbot|duckduckbot|msnbot|petalbot).*"
        }
      ],
      "destination": "/api/catalog-handler"
    },
    {
      "source": "/:slug/catalogo/:productId",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(facebookexternalhit|facebot|twitterbot|linkedinbot|slackbot|discordbot|telegrambot|whatsapp|pinterest|skypeuripreview|embedly|vkshare|w3c_validator|redditbot|applebot|yandex|googlebot|bingbot|duckduckbot|msnbot|petalbot).*"
        }
      ],
      "destination": "/api/catalog-handler"
    },
    {
      "source": "/((?!api|assets|favicon|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.(js|css|woff2|woff|ttf|svg|jpg|jpeg|png|webp|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
